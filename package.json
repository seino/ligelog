{
  "name": "ligelog",
  "version": "0.1.1",
  "description": "Lightweight, fast, hook-based JSON logger for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "bench": "npm run build && node --expose-gc bench/index.js",
    "bench:compare": "npm run bench",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "logger",
    "logging",
    "json",
    "ndjson",
    "fast",
    "lightweight",
    "nodejs",
    "typescript",
    "structured-logging"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seino/ligelog.git"
  },
  "homepage": "https://github.com/seino/ligelog#readme",
  "bugs": {
    "url": "https://github.com/seino/ligelog/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "pino": "^10.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "@sentry/node": ">=7"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
