{
  "name": "@ligelog/http",
  "version": "1.0.0",
  "description": "HTTP request logging middleware for ligelog — Express, Fastify, and Hono",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/express.ts src/hono.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ligelog",
    "http",
    "middleware",
    "express",
    "hono",
    "logging",
    "request-logging"
  ],
  "author": "Akihiro Seino",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seino/ligelog.git",
    "directory": "packages/http"
  },
  "homepage": "https://github.com/seino/ligelog#ecosystem",
  "bugs": {
    "url": "https://github.com/seino/ligelog/issues"
  },
  "devDependencies": {
    "ligelog": "workspace:*",
    "hono": "^4.0.0"
  },
  "peerDependencies": {
    "ligelog": ">=1.0.0",
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
