{
  "name": "@ligelog/pretty",
  "version": "1.0.0",
  "description": "Pretty-print transport for ligelog — colorized human-readable output for development",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ligelog",
    "pretty",
    "colorize",
    "transport",
    "logging",
    "development"
  ],
  "author": "Akihiro Seino",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seino/ligelog.git",
    "directory": "packages/pretty"
  },
  "homepage": "https://github.com/seino/ligelog#ecosystem",
  "bugs": {
    "url": "https://github.com/seino/ligelog/issues"
  },
  "devDependencies": {
    "ligelog": "workspace:*"
  },
  "peerDependencies": {
    "ligelog": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
